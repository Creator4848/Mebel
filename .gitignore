frontend/npm-debug.log*

# Python / FastAPI
backend/__pycache__/
backend/**/__pycache__/
backend/*.pyc
backend/.env
backend/alembic/versions/
backend/venv/
backend/.venv/

# Misc
.DS_Store
*.log
